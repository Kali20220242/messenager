{
  "name": "messenger-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/mobile"
  ],
  "scripts": {
    "mobile": "npm run start --workspace @messenger/mobile",
    "mobile:android": "npm run android --workspace @messenger/mobile",
    "mobile:ios": "npm run ios --workspace @messenger/mobile",
    "mobile:web": "npm run web --workspace @messenger/mobile",
    "mobile:typecheck": "npm run typecheck --workspace @messenger/mobile",
    "backend": "cargo run -p messenger-backend",
    "backend:check": "cargo check -p messenger-backend"
  }
}

